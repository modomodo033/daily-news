    },
    {
      "time": 560.0,
      "text": "药物研发、"
    },
    {
      "time": 562.7,
      "text": "慢病管理等方向发挥重要作用。"
    },
    {
      "time": 565.3,
      "text": "在教育领域，"
    },
    {
      "time": 567.9,
      "text": "粉笔公司创始人张小龙辞任CEO，"
    },
    {
      "time": 570.5,
      "text": "引发市场对AI教育转型的关注。"
    },
    {
      "time": 573.1,
      "text": "AI个性化学习、"
    },
    {
      "time": 575.8,
      "text": "智能批改、"
    },
    {
      "time": 578.4,
      "text": "虚拟老师等应用正在改变传统教育模式。"
    },
    {
      "time": 581.0,
      "text": "",
      "section": "AI投资与产业"
    },
    {
      "time": 581.5,
      "text": "资本市场对AI的态度正在分化。"
    },
    {
      "time": 583.9,
      "text": "一方面，"
    },
    {
      "time": 586.8,
      "text": "算力产业链上市公司半年报业绩亮眼，"
    },
    {
      "time": 589.7,
      "text": "浪潮信息预计上半年净利润增长226%到288%，"
    },
    {
      "time": 592.6,
      "text": "多家AI芯片、"
    },
    {
      "time": 595.4,
      "text": "存储、"
    },
    {
      "time": 598.3,
      "text": "算力租赁公司业绩预增。"
    },
    {
      "time": 601.2,
      "text": "另一方面，"
    },
    {
      "time": 604.1,
      "text": "市场对AI投资回报率的讨论越来越激烈，"
    },
    {
      "time": 607.0,
      "text": "美光科技股价自高点回调约23%，"
    },
    {
      "time": 609.9,
      "text": "投资者担心内存周期是否接近顶部。"
    },
    {
      "time": 612.8,
      "text": "从投资趋势看，"
    },
    {
      "time": 615.7,
      "text": "资金正在从纯概念炒作转向有业绩兑现能力的环节。"
    },
    {
      "time": 618.5,
      "text": "算力租赁、"
    },
    {
      "time": 621.4,
      "text": "AI应用、"
    },
    {
      "time": 624.3,
      "text": "人形机器人、"
    },
    {
      "time": 627.2,
      "text": "自动驾驶等领域持续获得资本青睐。"
    },
    {
      "time": 630.1,
      "text": "可灵AI融资30亿美元、"
    },
    {
      "time": 633.0,
      "text": "SpaceX收购Cursor等大额交易，"
    },
    {
      "time": 635.9,
      "text": "说明头部AI资产仍然稀缺。"
    },
    {
      "time": 638.8,
      "text": "中国AI核心产业规模已突破1.2万亿元，"
    },
    {
      "time": 641.6,
      "text": "今年人形机器人整机产量有望突破10万台。"
    },
    {
      "time": 644.5,
      "text": "AI正在从技术创新走向产业创新，"
    },
    {
      "time": 647.4,
      "text": "从实验室走向生产线，"
    },
    {
      "time": 650.3,
      "text": "成为推动经济高质量发展的重要引擎。"
    },
    {
      "time": 653.2,
      "text": "",
      "section": "AI未来展望"
    },
    {
      "time": 653.7,
      "text": "总的来说，"
    },
    {
      "time": 655.8,
      "text": "今天的AI世界依然是风起云涌。"
    },
    {
      "time": 658.3,
      "text": "大模型性能不断突破，"
    },
    {
      "time": 660.9,
      "text": "GPT-5.6、"
    },
    {
      "time": 663.4,
      "text": "Grok 4.5、"
    },
    {
      "time": 666.0,
      "text": "Gemini 3.5 Pro你方唱罢我登场；"
    },
    {
      "time": 668.6,
      "text": "AI安全问题浮出水面，"
    },
    {
      "time": 671.1,
      "text": "Claude Code后门事件敲响警钟；"
    },
    {
      "time": 673.7,
      "text": "AI视频、"
    },
    {
      "time": 676.3,
      "text": "AI芯片、"
    },
    {
      "time": 678.8,
      "text": "自动驾驶、"
    },
    {
      "time": 681.4,
      "text": "AI医疗等应用加速落地；"
    },
    {
      "time": 683.9,
      "text": "国产大模型出海势头强劲。"
    },
    {
      "time": 686.5,
      "text": "科技改变世界，"
    },
    {
      "time": 689.1,
      "text": "但也需要我们更加理性地看待风险与机遇。"
    },
    {
      "time": 691.6,
      "text": "小雷会继续为爸爸妈妈追踪AI世界的最新动态。"
    },
    {
      "time": 694.2,
      "text": "感谢收听今天的AI要闻播报，"
    },
    {
      "time": 696.8,
      "text": "科技改变世界，"
    },
    {
      "time": 699.3,
      "text": "小雷明天继续为你追踪哦。"
    },
    {
      "time": 701.9,
      "text": "爸爸妈妈今日播报完毕，"
    },
    {
      "time": 704.4,
      "text": "雷子永远爱你们呦！"
    }
